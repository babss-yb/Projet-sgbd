{
  "name": "transpobot-frontend",
  "version": "1.0.0",
  "description": "TranspoBot - Frontend React pour la gestion de transport urbain avec IA",
  "private": true,
  "dependencies": {
    "axios": "^1.6.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-scripts": "5.0.1",
    "recharts": "^2.10.3"
  },
  "scripts": {
    "dev": "set \"HOST=127.0.0.1\"&& set \"PORT=3001\"&& set \"DANGEROUSLY_DISABLE_HOST_CHECK=true\"&& node --max-http-header-size=262144 ./node_modules/react-scripts/bin/react-scripts.js start",
    "start": "set \"HOST=127.0.0.1\"&& set \"PORT=3001\"&& set \"DANGEROUSLY_DISABLE_HOST_CHECK=true\"&& node --max-http-header-size=262144 ./node_modules/react-scripts/bin/react-scripts.js start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://127.0.0.1:3002",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19"
